# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
bin/

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Python
__pycache__/
*.py[cod]
*$py.class
.mypy_cache/
.pytest_cache/

# Links created by the mise plugin
.vscode/mise-tools/

# Project-local Python venv (pre-commit, etc.)
.venv/

# Prefetched deps for local build (CI uses Hermeto; see scripts/prepare-oc-client-for-build.sh)
deps/

# IDE / editor
.cursor/plans/
.idea/
*.swp
*.swo

# macOS
.DS_Store
