[general]
contrib=contrib-title-conventional-commits,contrib-body-requires-signed-off-by
regex-style-search=True

[title-max-length]
line-length=72

[body-max-line-length]
line-length=72

[body-first-line-empty]

# Bot users tend to generate invalid commits (no body, no Signed-off-by).
# "fullsend" matches all fullsend bot accounts, including fullsend-code
# (fullsend-ai-coder[bot]'s git author name), not just fullsend-ai-fullsend.
[ignore-by-author-name]
regex=(red-hat-trusted-app-pipeline|red-hat-konflux|fullsend|\[bot\])
ignore=all
